{
  description = "Development Shell";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs/nixos-26.05";
    coding-utilities-src = {
    url = "github:muralivnv/coding_utilities?rev=01092b420f4a9c2eef7bf3992a543164c0dc7437";
    inputs.nixpkgs.follows = "nixpkgs";
    };
    ghostty-src = { url = "https://github.com/pkgforge-dev/ghostty-appimage/releases/download/v1.3.1/Ghostty-1.3.1-x86_64.AppImage"; flake = false; };
  };

  outputs = { self, nixpkgs, coding-utilities-src, ghostty-src, ... }:
    let
      system = "x86_64-linux";
      pkgs = import nixpkgs { inherit system; };
      
      coding-utilities = coding-utilities-src.packages.${system}.default;

      ghostty = pkgs.stdenvNoCC.mkDerivation {
        pname = "ghostty";
        version = "1.3.1";
        src = ghostty-src;
        dontUnpack = true; 
        installPhase = ''
          mkdir -p $out/bin
          # Copy the raw AppImage directly to the bin folder
          cp $src $out/bin/ghostty
          chmod +x $out/bin/ghostty
        '';
      };

      flakeDir = "${self}";

    in {
      devShells.${system}.default = pkgs.mkShellNoCC {
        name = "devshell";
        buildInputs = with pkgs; [
          gitMinimal fzf bat zoxide starship pastel yazi-unwrapped tmux helix
          uv python314 moreutils socat ghostty distrobox chezmoi
          coding-utilities

          # Inject machine-specific packages from chezmoi data
          {{- range .extra_nix_packages }}
          {{ . }}
          {{- end }}
        ];

        env = {
          UV_PYTHON_PREFERENCE = "only-system";
          UV_PYTHON_DOWNLOADS = "never";
          UV_PYTHON = "${pkgs.python314}/bin/python";
        };

        shellHook = ''
          NIX_LIBS="${pkgs.lib.makeLibraryPath [
            pkgs.stdenv.cc.cc.lib
            pkgs.libz
          ]}"
          export LD_LIBRARY_PATH="$NIX_LIBS''${LD_LIBRARY_PATH:+:}$LD_LIBRARY_PATH"

          source ${flakeDir}/bash_custom_functions.sh
          source ${flakeDir}/fzf-bash-completion.sh
          source ${flakeDir}/bash_config.sh
        '';
      };
    };

}   
